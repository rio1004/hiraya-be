generator client {
  provider     = "prisma-client-js"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  name        String?
  createdAt   DateTime  @default(now())
  firebaseUid String?   @unique
  role        Role      @default(CUSTOMER)
  firstName   String?
  mobile      String?
  lastName    String?
  addresses   Address[]
  carts       Cart?
  orders      Order[]
}

model Category {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id          String           @id @default(uuid())
  name        String
  description String?
  isActive    Boolean          @default(true)
  categoryId  String
  createdAt   DateTime         @default(now())
  category    Category         @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
}

model ProductVariant {
  id           String             @id @default(uuid())
  productId    String
  color        String
  texture      String
  walletType   WalletType
  price        Decimal            @db.Decimal(10, 2)
  stock        Int                @default(0)
  availability AvailabilityStatus
  sku          String?            @unique
  createdAt    DateTime           @default(now())
  imgSrc       String?
  cartItems    CartItem[]
  orderItems   OrderItem[]
  product      Product            @relation(fields: [productId], references: [id])

  @@index([productId])
}

model Address {
  barangayCode String
  cityCode     String
  contactName  String
  contactPhone String
  fullAddress  String
  createdAt    DateTime  @default(now())
  isDefault    Boolean   @default(false)
  postalCode   String
  provinceCode String?
  regionCode   String
  userId       String
  id           Int       @id @default(autoincrement())
  barangay     Barangay  @relation(fields: [barangayCode], references: [code])
  city         City      @relation(fields: [cityCode], references: [code])
  province     Province? @relation(fields: [provinceCode], references: [code])
  region       Region    @relation(fields: [regionCode], references: [code])
  user         User      @relation(fields: [userId], references: [id])
  orders       Order[]

  @@index([userId])
}

model ShippingFee {
  id     Int          @id @default(autoincrement())
  zoneId Int
  fee    Decimal
  zone   ShippingZone @relation(fields: [zoneId], references: [id])
}

model RegionZone {
  id         Int          @id @default(autoincrement())
  zoneId     Int
  regionCode String
  region     Region       @relation(fields: [regionCode], references: [code])
  zone       ShippingZone @relation(fields: [zoneId], references: [id])

  @@unique([zoneId, regionCode])
}

model ShippingZone {
  id           Int           @id @default(autoincrement())
  name         String
  regions      RegionZone[]
  shippingFees ShippingFee[]
}

model Region {
  name        String
  code        String       @id
  createdAt   DateTime     @default(now())
  addresses   Address[]
  cities      City[]
  provinces   Province[]
  regionZones RegionZone[]
}

model PostalCode {
  id           Int       @id @default(autoincrement())
  code         String
  cityCode     String
  barangayCode String?
  barangay     Barangay? @relation(fields: [barangayCode], references: [code])
  city         City      @relation(fields: [cityCode], references: [code])

  @@index([code])
}

model Province {
  name       String
  code       String    @id
  createdAt  DateTime  @default(now())
  regionCode String
  addresses  Address[]
  cities     City[]
  region     Region    @relation(fields: [regionCode], references: [code])

  @@index([regionCode])
}

model City {
  name         String
  code         String       @id
  createdAt    DateTime     @default(now())
  provinceCode String?
  regionCode   String
  addresses    Address[]
  barangays    Barangay[]
  province     Province?    @relation(fields: [provinceCode], references: [code])
  region       Region       @relation(fields: [regionCode], references: [code])
  postalCodes  PostalCode[]

  @@index([provinceCode])
  @@index([regionCode])
}

model Barangay {
  name        String
  cityCode    String
  code        String       @id
  createdAt   DateTime     @default(now())
  addresses   Address[]
  city        City         @relation(fields: [cityCode], references: [code])
  postalCodes PostalCode[]

  @@index([cityCode])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
}

model CartItem {
  id        String         @id @default(uuid())
  cartId    String
  variantId String
  quantity  Int            @default(1)
  cart      Cart           @relation(fields: [cartId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([variantId])
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  addressId   Int?
  total       Decimal     @db.Decimal(10, 2)
  createdAt   DateTime    @default(now())
  deliveryFee Decimal?    @db.Decimal(10, 2)
  status      OrderStatus
  address     Address?    @relation(fields: [addressId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]

  @@index([userId])
}

model OrderItem {
  id        String         @id @default(uuid())
  orderId   String
  variantId String
  quantity  Int
  price     Decimal        @db.Decimal(10, 2)
  order     Order          @relation(fields: [orderId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
}

enum WalletType {
  BIFOLD
  TRIFOLD
  LONG
  CARDHOLDER
}

enum AvailabilityStatus {
  IN_STOCK
  OUT_OF_STOCK
  PREORDER
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
